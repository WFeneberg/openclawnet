@page "/skills"
@rendermode InteractiveServer

<PageTitle>OpenClaw - Skills</PageTitle>

<h3>Skills</h3>

<p class="text-muted">
    Skills are markdown-based instructions that customize the agent's behavior.
    Place skill files in the <code>skills/</code> directory.
</p>

<div class="mb-3">
    <button class="btn btn-outline-secondary btn-sm" @onclick="ReloadSkills">
        🔄 Reload Skills
    </button>
</div>

<div class="row g-3">
    @foreach (var skill in _skills)
    {
        <div class="col-md-6">
            <div class="card h-100 @(!skill.Enabled ? "border-secondary opacity-75" : "")">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="card-title">@skill.Name</h5>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" checked="@skill.Enabled"
                                   @onchange="() => ToggleSkill(skill)" />
                        </div>
                    </div>
                    <p class="card-text">@skill.Description</p>
                    @if (!string.IsNullOrEmpty(skill.Category))
                    {
                        <span class="badge bg-secondary me-1">@skill.Category</span>
                    }
                    @foreach (var tag in skill.Tags)
                    {
                        <span class="badge bg-info me-1">@tag</span>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private readonly List<SkillInfo> _skills =
    [
        new("dotnet-assistant", "Helps with .NET development tasks, code reviews, and best practices.", "development", true, ["dotnet", "csharp", "coding"]),
        new("repo-analyzer", "Analyzes repository structure, code patterns, and project health.", "analysis", true, ["analysis", "repository", "code-review"]),
        new("blog-writer", "Helps write technical blog posts and documentation.", "writing", false, ["writing", "blog", "documentation"]),
        new("azure-helper", "Assists with Azure cloud services, deployment, and configuration.", "cloud", false, ["azure", "cloud", "deployment"])
    ];
    
    private void ToggleSkill(SkillInfo skill)
    {
        var index = _skills.IndexOf(skill);
        if (index >= 0)
        {
            _skills[index] = skill with { Enabled = !skill.Enabled };
        }
    }
    
    private void ReloadSkills()
    {
        // Will be wired to Gateway API
    }
    
    private sealed record SkillInfo(string Name, string Description, string? Category, bool Enabled, string[] Tags);
}
