@page "/settings"
@rendermode InteractiveServer

<PageTitle>OpenClaw - Settings</PageTitle>

<h3>Settings</h3>

<div class="row">
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header">Model Provider</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Provider</label>
                    <select class="form-select" @bind="_provider">
                        <option value="ollama">Ollama (Local)</option>
                        <option value="azure-openai" disabled>Azure OpenAI (Coming Soon)</option>
                        <option value="foundry" disabled>Microsoft Foundry (Coming Soon)</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Model</label>
                    <input type="text" class="form-control" @bind="_model" placeholder="llama3.2" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Endpoint</label>
                    <input type="text" class="form-control" @bind="_endpoint" placeholder="http://localhost:11434" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Temperature</label>
                    <input type="range" class="form-range" min="0" max="2" step="0.1" @bind="_temperature" />
                    <span>@_temperature</span>
                </div>
            </div>
        </div>
        
        <div class="card">
            <div class="card-header">System Info</div>
            <div class="card-body">
                <table class="table table-sm">
                    <tr><td>Version</td><td>0.1.0</td></tr>
                    <tr><td>Runtime</td><td>.NET @Environment.Version</td></tr>
                    <tr><td>OS</td><td>@Environment.OSVersion</td></tr>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private string _provider = "ollama";
    private string _model = "llama3.2";
    private string _endpoint = "http://localhost:11434";
    private double _temperature = 0.7;
}
